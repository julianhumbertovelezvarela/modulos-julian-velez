rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // For now, checking if user is in the 'admins' collection
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // Doctors
    // -------------------------------------------------------------------------
    match /doctors/{doctorId} {
      function isValidDoctor(data) {
        return data.id is number &&
               data.nombre is string && data.nombre.size() > 0 && data.nombre.size() < 200 &&
               data.cat in ['Planta', 'CTA', 'APS'] &&
               data.st in ['activo', 'inactivo'] &&
               data.username is string && data.username.size() > 0 &&
               data.password is string && data.password.size() >= 4 &&
               (data.get('contacto', '') is string);
      }

      // Public read for doctor profiles (needed for current login mechanism)
      // Ideally this should be restricted to authenticated users or removed once AI Auth is implemented
      allow get: if true;
      allow list: if true; // Fetch all to find by username/password in code (INSECURE - fix later)

      allow create: if isAdmin() && isValidDoctor(incoming());
      
      allow update: if (
        (isAdmin() && isValidDoctor(incoming())) ||
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['password', 'passwordLastChanged']) &&
         incoming().password is string && incoming().password.size() >= 4)
      );

      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Audit Logs
    // -------------------------------------------------------------------------
    match /auditLogs/{logId} {
      function isValidAuditLog(data) {
        return data.id is number &&
               data.timestamp is number &&
               data.targetMonth is number &&
               data.targetYear is number &&
               data.doctorId is number &&
               data.doctorName is string &&
               data.day is number &&
               data.slot in ['m', 't', 'n'] &&
               data.oldSigla is string &&
               data.newSigla is string &&
               data.adminName is string;
      }

      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidAuditLog(incoming());
      allow update, delete: if false; // Immutable
    }

    // -------------------------------------------------------------------------
    // Shift Requests
    // -------------------------------------------------------------------------
    match /shiftRequests/{reqId} {
      function isValidShiftRequest(data) {
        return data.id is number &&
               data.timestamp is number &&
               data.doctorId is number &&
               data.doctorName is string &&
               data.day is number &&
               data.slot in ['m', 't', 'n'] &&
               data.reason is string && data.reason.size() > 0 && data.reason.size() < 2000 &&
               data.status in ['pending', 'approved', 'rejected'] &&
               data.targetMonth is number &&
               data.targetYear is number;
      }

      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && isValidShiftRequest(incoming()) && incoming().status == 'pending';
      
      allow update: if (
        (isAdmin() && isValidShiftRequest(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        (isSignedIn() && existing().status == 'pending' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['reason', 'day', 'slot']))
      );

      allow delete: if isAdmin() || (isSignedIn() && existing().status == 'pending');
    }

    // -------------------------------------------------------------------------
    // Monthly Data
    // -------------------------------------------------------------------------
    match /monthlyData/{monthKey} {
      allow read: if true; // Public for now
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Settings
    // -------------------------------------------------------------------------
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Notifications
    // -------------------------------------------------------------------------
    match /notifications/{noteId} {
      function isValidNotification(data) {
        return data.doctorId is number &&
               data.message is string && data.message.size() > 0 &&
               data.read is boolean &&
               data.timestamp is number;
      }

      allow read: if isSignedIn(); // Currently App.tsx filters by doctorId in query
      allow create: if isAdmin() && isValidNotification(incoming());
      allow update: if isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }
  }
}
