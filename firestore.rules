rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admins
    match /admins/{uid} {
      allow read, write: if true;
    }

    // Doctors
    match /doctors/{doctorId} {
      allow read, write: if true;
    }

    // Audit Logs
    match /auditLogs/{logId} {
      allow read, write: if true;
    }

    // Shift Requests
    match /shiftRequests/{reqId} {
      allow read, write: if true;
    }

    // Monthly Data
    match /monthlyData/{monthKey} {
      allow read, write: if true;
      
      match /doctors/{docId} {
        allow read, write: if true;
      }
    }

    // Settings
    match /settings/{docId} {
      allow read, write: if true;
    }

    // Notifications
    match /notifications/{noteId} {
      allow read, write: if true;
    }

    // Rural Availability
    match /ruralAvailability/{id} {
      allow read, write: if true;
    }

    // Availability Logs
    match /availabilityCalls/{id} {
      allow read, write: if true;
    }

    // Training Activities
    match /trainingActivities/{activityId} {
      allow read, write: if true;
    }

    // Census (Collaborative patient tracking)
    match /census/{patientId} {
      allow read, write: if true;
    }

    // Handovers (Shift delivery)
    match /handovers/{handoverId} {
      allow read, write: if true;
    }

    // Test connection
    match /test/connection {
      allow read, write: if true;
    }
  }
}
