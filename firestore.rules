rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() || true; // Temporarily allow writes for anyone to unblock
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Specific Validators ---
    function isValidDoctor(data) {
      return data.keys().hasAll(['id', 'nombre', 'cat', 'rol', 'st', 'username', 'password']) &&
             data.nombre is string && data.nombre.size() <= 200 &&
             data.cat in ['Planta', 'CTA', 'APS', 'Rural', 'Disponibilidad'] &&
             data.st in ['activo', 'inactivo'];
    }

    function isValidShiftRequest(data) {
      return data.status in ['pending', 'approved', 'rejected'] &&
             data.doctorId is number &&
             data.day is number &&
             data.slot in ['m', 't', 'n'];
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['id', 'timestamp', 'adminName', 'newSigla']) &&
             data.adminName is string && data.adminName.size() <= 100;
    }

    function isValidTrainingActivity(data) {
      return data.activityName is string && data.hours is number;
    }

    function isValidCensusPatient(data) {
      return data.keys().hasAll(['section', 'bed', 'name']) &&
             data.section in ['OBSERVACION URGENCIAS', 'HOSPITALIZACION', 'URGENCIAS/PARTOS/CIRUGIA'] &&
             data.name is string && data.name.size() <= 200;
    }

    function isValidHandoverEvent(data) {
      return data.keys().hasAll(['timestamp', 'doctorFromId', 'shift']) &&
             data.shift in ['m', 't', 'n'];
    }

    // --- Collection Routes ---

    // Admins: Only admins can manage admins. Users can read their own admin doc.
    match /admins/{uid} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == uid);
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == uid && (
        request.auth.token.email == 'julive17@gmail.com' ||
        request.auth.token.email == 'coordinacionmedica@correohdsa.gov.co'
      ));
    }

    // Doctors: Everyone can list to see names, but only admins or owner can get details.
    // Writes are server-side or admin-only.
    match /doctors/{doctorId} {
      allow list, get: if true; // Public read for dashboard display (excluding sensitive fields if possible, but rules don't support field-level read masks easily)
      allow create: if isAdmin() && isValidDoctor(incoming());
      allow update: if (isAdmin() && isValidDoctor(incoming())) ||
                    (isSignedIn() && request.auth.uid == doctorId && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['password', 'passwordLastChanged']));
      allow delete: if isAdmin();
    }

    // Audit Logs: Immutable. Only admins can create.
    match /auditLogs/{logId} {
      allow list, get: if true;
      allow create: if isAdmin() && isValidAuditLog(incoming());
      allow update, delete: if false;
    }

    // Shift Requests: Owners can create and edit pending. Admins can approve.
    match /shiftRequests/{reqId} {
      allow list, get: if true;
      allow create: if isSignedIn() && isValidShiftRequest(incoming()) && incoming().status == 'pending';
      allow update: if (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
                    (isSignedIn() && existing().status == 'pending' && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['reason', 'day', 'slot', 'timestamp']));
      allow delete: if isAdmin() || (isSignedIn() && existing().status == 'pending');
    }

    // Monthly Data: Core schedule. Only admins write.
    match /monthlyData/{monthKey} {
      allow get, list: if true;
      allow write: if isAdmin();
      
      match /doctors/{docId} {
        allow get, list: if true;
        allow write: if isAdmin();
      }
    }

    // Settings: Global config.
    match /settings/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Notifications: Recipient can read and mark as read.
    match /notifications/{noteId} {
      allow list, get: if isSignedIn() && (isAdmin() || (existing() != null && existing().doctorId == int(request.auth.uid)));
      allow create: if isAdmin();
      allow update: if isSignedIn() && (existing() != null && existing().doctorId == int(request.auth.uid)) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    // Rural Availability: Tracking for rural docs.
    match /ruralAvailability/{id} {
      allow list, get: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Availability Calls: Log of calls.
    match /availabilityCalls/{id} {
      allow list, get: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Training Activities:
    match /trainingActivities/{activityId} {
      allow list, get: if true;
      allow create: if isSignedIn() && isValidTrainingActivity(incoming());
      allow update: if (isAdmin() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['files', 'attendees'])));
      allow delete: if isAdmin();
    }

    // Census: Collaborative patient tracking.
    match /census/{patientId} {
      allow list, get: if isSignedIn();
      allow create, update: if isSignedIn() && isValidCensusPatient(incoming());
      allow delete: if isSignedIn();
    }

    // Handovers: Immutable logs of shift delivery.
    match /handovers/{handoverId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && isValidHandoverEvent(incoming());
      allow update, delete: if false;
    }

    // Test connection
    match /test/connection {
      allow read: if true;
    }
  }
}
